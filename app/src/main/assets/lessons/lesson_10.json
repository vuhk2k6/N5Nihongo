  "grammar": [
    {
      "grammarId": 1001,
      "lessonId": 10,
      "title": "N(場所) に N が あります/います",
      "structure": "N に N が あります/います",
      "explanation": "Có cái gì ở đâu. あります dùng cho đồ vật, います dùng cho người/động vật.",
      "examples": [
        {
          "japanese": "机の 上に 本が あります。",
          "vietnamese": "Trên bàn có quyển sách."
        },
        {
          "japanese": "部屋に 猫が います。",
          "vietnamese": "Trong phòng có con mèo."
        }
      ]
    },
    {
      "grammarId": 1002,
      "lessonId": 10,
      "title": "N は N(場所) に あります/います",
      "structure": "N は N に あります/います",
      "explanation": "Diễn đạt vị trí. ~ ở đâu? Chủ thể N được nhấn mạnh nên đặt trước は.",
      "examples": [
        {
          "japanese": "銀行は 駅の 近くに あります。",
          "vietnamese": "Ngân hàng ở gần ga."
        },
        {
          "japanese": "ミラーさんは 事務所に います。",
          "vietnamese": "Anh Miller đang ở văn phòng."
        }
      ]
    },
    {
      "grammarId": 1003,
      "lessonId": 10,
      "title": "N1 の (vị trí) に",
      "structure": "N の うえ/した/まえ/うしろ… に",
      "explanation": "Dùng の để nối danh từ với từ chỉ vị trí.",
      "examples": [
        {
          "japanese": "椅子の 下に かばんが あります。",
          "vietnamese": "Có cái cặp ở dưới ghế."
        },
        {
          "japanese": "銀行と 郵便局の 間に 花屋が あります。",
          "vietnamese": "Giữa ngân hàng và bưu điện có tiệm hoa."
        }
      ]
    },
    {
      "grammarId": 1004,
      "lessonId": 10,
      "title": "N1 や N2 (など)",
      "structure": "N1 や N2 (など)",
      "explanation": "Liệt kê không đầy đủ. や = và, など = vân vân.",
      "examples": [
        {
          "japanese": "箱の 中に 手紙や 写真などが あります。",
          "vietnamese": "Trong hộp có thư, ảnh, vv..."
        },
        {
          "japanese": "ロビーに 男の人や 女の人が います。",
          "vietnamese": "Trong sảnh có cả đàn ông và phụ nữ."
        }
      ]
    }
  ],
