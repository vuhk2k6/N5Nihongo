  "grammar": [
    {
      "grammarId": 101,
      "lessonId": 1,
      "title": "N1 は N2 です",
      "structure": "N1 は N2 です",
      "explanation": "Trợ từ は (đọc wa) biểu thị N1 là chủ đề. です kết thúc câu khẳng định lịch sự. Câu nghĩa là N1 là N2.",
      "examples": [
        {
          "japanese": "わたしは マイク・ミラーです。",
          "vietnamese": "Tôi là Mike Miller."
        },
        {
          "japanese": "サントスさんは 学生です。",
          "vietnamese": "Anh Santos là học sinh."
        },
        {
          "japanese": "ワットさんは 先生です。",
          "vietnamese": "Ông Watt là giáo viên."
        }
      ]
    },
    {
      "grammarId": 102,
      "lessonId": 1,
      "title": "N1 は N2 じゃ ありません",
      "structure": "N1 は N2 じゃ/では ありません",
      "explanation": "じゃ ありません (じゃ ありません = dạng phủ định của です). N1 không phải là N2.",
      "examples": [
        {
          "japanese": "サントスさんは 学生 じゃ ありません。",
          "vietnamese": "Anh Santos không phải là học sinh."
        },
        {
          "japanese": "わたしは エンジニア では ありません。",
          "vietnamese": "Tôi không phải là kỹ sư."
        }
      ]
    },
    {
      "grammarId": 103,
      "lessonId": 1,
      "title": "N1 は N2 ですか",
      "structure": "N1 は N2 ですか",
      "explanation": "Thêm か vào cuối câu để tạo câu hỏi Yes/No. Trả lời: はい、そうです / いいえ、ちがいます.",
      "examples": [
        {
          "japanese": "ミラーさんは 会社員ですか。",
          "vietnamese": "Anh Miller là nhân viên công ty phải không?"
        },
        {
          "japanese": "はい、会社員です。",
          "vietnamese": "Vâng, anh ấy là nhân viên công ty."
        },
        {
          "japanese": "いいえ、会社員 じゃ ありません。",
          "vietnamese": "Không, anh ấy không phải nhân viên công ty."
        }
      ]
    },
    {
      "grammarId": 104,
      "lessonId": 1,
      "title": "N も N です",
      "structure": "N1 も N2 です",
      "explanation": "Trợ từ も thay cho は khi muốn nói 'cũng'. N1 cũng là N2.",
      "examples": [
        {
          "japanese": "ミラーさんは 会社員です。グプタさんも 会社員です。",
          "vietnamese": "Anh Miller là nhân viên công ty. Anh Gupta cũng là nhân viên công ty."
        },
        {
          "japanese": "わたしも ベトナム人です。",
          "vietnamese": "Tôi cũng là người Việt Nam."
        }
      ]
    }
  ],
