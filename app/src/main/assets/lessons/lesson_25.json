  "grammar": [
    {
      "grammarId": 2501,
      "lessonId": 25,
      "title": "V(た形) / い-adj / な-adj / N + ら、～",
      "structure": "～たら、～",
      "explanation": "Câu điều kiện. Nếu/sau khi ~ thì ~. い-adj: ～かったら. な-adj/N: ～だったら.",
      "examples": [
        {
          "japanese": "雨が 降ったら、出かけません。",
          "vietnamese": "Nếu trời mưa thì tôi không ra ngoài."
        },
        {
          "japanese": "安かったら、買います。",
          "vietnamese": "Nếu rẻ thì tôi sẽ mua."
        },
        {
          "japanese": "10時に なったら、出かけましょう。",
          "vietnamese": "Đến 10 giờ thì chúng ta đi nhé."
        }
      ]
    },
    {
      "grammarId": 2502,
      "lessonId": 25,
      "title": "V て / い-adj くて / な-adj で / N で + も、～",
      "structure": "～ても、～",
      "explanation": "Câu nhượng bộ. Cho dù ~ thì cũng ~.",
      "examples": [
        {
          "japanese": "雨が 降っても、出かけます。",
          "vietnamese": "Cho dù trời mưa tôi cũng ra ngoài."
        },
        {
          "japanese": "高くても、買います。",
          "vietnamese": "Cho dù đắt tôi cũng sẽ mua."
        },
        {
          "japanese": "日曜日でも、働きます。",
          "vietnamese": "Cho dù chủ nhật tôi cũng làm việc."
        }
      ]
    },
    {
      "grammarId": 2503,
      "lessonId": 25,
      "title": "もし～たら、～",
      "structure": "もし + V(た形) ら、～",
      "explanation": "Câu giả định. Nếu giả sử ~ thì ~. もし đi kèm với たら để nhấn mạnh giả định.",
      "examples": [
        {
          "japanese": "もし 1億円 あったら、世界中を 旅行したいです。",
