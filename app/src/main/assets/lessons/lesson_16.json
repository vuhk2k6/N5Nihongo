  "grammar": [
    {
      "grammarId": 1601,
      "lessonId": 16,
      "title": "V1 て、V2 て、V3",
      "structure": "V1 て、V2 て、V3",
      "explanation": "Nối các hành động theo thứ tự thời gian (3 hành động trở lên).",
      "examples": [
        {
          "japanese": "朝 起きて、ご飯を 食べて、学校へ 行きます。",
          "vietnamese": "Sáng dậy, ăn cơm, rồi đi học."
        },
        {
          "japanese": "デパートへ 行って、買い物して、映画を 見ました。",
          "vietnamese": "Tôi đã đi trung tâm, mua sắm rồi xem phim."
        }
      ]
    },
    {
      "grammarId": 1602,
      "lessonId": 16,
      "title": "V1 てから、V2",
      "structure": "V1 てから、V2",
      "explanation": "Sau khi làm V1 rồi mới làm V2. Nhấn mạnh thứ tự, chỉ dùng từ にてから đến một lần trong câu.",
      "examples": [
        {
          "japanese": "シャワーを 浴びてから、寝ます。",
          "vietnamese": "Sau khi tắm, tôi đi ngủ."
        },
        {
          "japanese": "大学を 卒業してから、会社で 働きます。",
          "vietnamese": "Sau khi tốt nghiệp đại học, tôi sẽ làm ở công ty."
        }
      ]
    },
    {
      "grammarId": 1603,
      "lessonId": 16,
      "title": "N は adj くて/で、adj です",
      "structure": "N は い-adj くて / な-adj で、adj です",
      "explanation": "Nối hai hoặc nhiều tính từ. い-adj: bỏ い thêm くて. な-adj: bỏ な thêm で.",
      "examples": [
        {
          "japanese": "ミラーさんは 若くて、元気です。",
          "vietnamese": "Anh Miller trẻ và khoẻ mạnh."
        },
        {
          "japanese": "奈良は 静かで、きれいな 町です。",
          "vietnamese": "Nara là một thành phố yên tĩnh và đẹp."
        }
      ]
    },
    {
      "grammarId": 1604,
      "lessonId": 16,
      "title": "N1 は N2 が adj です",
      "structure": "N1 は N2 が adj です",
      "explanation": "Mô tả đặc điểm của N1 thông qua N2. Bộ phận N2 thuộc tổng thể N1.",
      "examples": [
        {
          "japanese": "象は 鼻が 長いです。",
          "vietnamese": "Voi có cái mũi dài."
        },
        {
          "japanese": "大阪は 食べ物が おいしいです。",
          "vietnamese": "Đồ ăn Osaka ngon."
        }
      ]
    }
