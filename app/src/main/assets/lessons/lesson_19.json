  "grammar": [
    {
      "grammarId": 1901,
      "lessonId": 19,
      "title": "Cách chia た形",
      "structure": "た形 = て形 với て→た, で→だ",
      "explanation": "Tương tự て形 nhưng dùng た/だ thay cho て/で. Ví dụ: 飲んで → 飲んだ, 食べて → 食べた.",
      "examples": [
        {
          "japanese": "書きます → 書いた",
          "vietnamese": "kakimasu → kaita"
        },
        {
          "japanese": "飲みます → 飲んだ",
          "vietnamese": "nomimasu → nonda"
        },
        {
          "japanese": "食べます → 食べた",
          "vietnamese": "tabemasu → tabeta"
        }
      ]
    },
    {
      "grammarId": 1902,
      "lessonId": 19,
      "title": "V(た形) ことが あります",
      "structure": "V(た形) こと が あります",
      "explanation": "Diễn đạt kinh nghiệm. Đã từng làm ~. Phủ định: ことが ありません = chưa từng.",
      "examples": [
        {
          "japanese": "富士山に 登った ことが あります。",
          "vietnamese": "Tôi đã từng leo núi Phú Sĩ."
        },
        {
          "japanese": "馬に 乗った ことが ありません。",
          "vietnamese": "Tôi chưa từng cưỡi ngựa."
        }
      ]
    },
    {
      "grammarId": 1903,
      "lessonId": 19,
      "title": "V(た形)り、V(た形)り します",
      "structure": "V1 たり、V2 たり します",
      "explanation": "Liệt kê vài hành động đại diện trong nhiều hành động khác.",
      "examples": [
        {
          "japanese": "日曜日は 本を 読んだり、映画を 見たり します。",
          "vietnamese": "Chủ nhật tôi đọc sách, xem phim..."
        },
        {
          "japanese": "休みの 日は 音楽を 聞いたり、散歩したり します。",
          "vietnamese": "Ngày nghỉ tôi nghe nhạc, đi dạo..."
        }
      ]
    },
    {
      "grammarId": 1904,
      "lessonId": 19,
      "title": "い-adj く なります / な-adj・N に なります",
      "structure": "い-adj く なります / な-adj・N に なります",
      "explanation": "Diễn đạt sự thay đổi trạng thái. い-adj: bỏ い thêm くなります. な-adj/N: thêm になります.",
      "examples": [
        {
          "japanese": "最近 寒く なりました。",
          "vietnamese": "Gần đây trời lạnh hơn."
        },
        {
          "japanese": "もうすぐ 夏に なります。",
          "vietnamese": "Sắp đến mùa hè rồi."
        },
        {
          "japanese": "ミラーさんは 元気に なりました。",
