  "grammar": [
    {
      "grammarId": 601,
      "lessonId": 6,
      "title": "N を V ます",
      "structure": "N を V ます",
      "explanation": "Trợ từ を (đọc o) đánh dấu tân ngữ trực tiếp của động từ tha động.",
      "examples": [
        {
          "japanese": "パンを 食べます。",
          "vietnamese": "Tôi ăn bánh mì."
        },
        {
          "japanese": "コーヒーを 飲みます。",
          "vietnamese": "Tôi uống cà phê."
        }
      ]
    },
    {
      "grammarId": 602,
      "lessonId": 6,
      "title": "N(場所) で V ます",
      "structure": "N(場所) で V ます",
      "explanation": "Trợ từ で chỉ nơi diễn ra hành động.",
      "examples": [
        {
          "japanese": "食堂で ご飯を 食べます。",
          "vietnamese": "Tôi ăn cơm ở nhà ăn."
        },
        {
          "japanese": "図書館で 本を 読みます。",
          "vietnamese": "Tôi đọc sách ở thư viện."
        }
      ]
    },
    {
      "grammarId": 603,
      "lessonId": 6,
      "title": "V ませんか / V ましょう",
      "structure": "V ませんか / V ましょう",
      "explanation": "V ませんか = lời rủ nhẹ nhàng (Cùng làm ~ nhé?). V ましょう = đề nghị (Cùng làm ~ thôi).",
      "examples": [
        {
          "japanese": "いっしょに 昼ご飯を 食べませんか。",
          "vietnamese": "Cùng ăn trưa nhé?"
        },
        {
          "japanese": "ええ、食べましょう。",
          "vietnamese": "Vâng, cùng ăn nào."
        }
      ]
    },
    {
      "grammarId": 604,
      "lessonId": 6,
      "title": "なに / なん を V ますか",
      "structure": "何 を V ますか",
      "explanation": "何 (なに/なん) dùng để hỏi tân ngữ. Trước た, だ, な → なん. Trước các âm khác → なに.",
      "examples": [
        {
          "japanese": "週末 何を しますか。",
          "vietnamese": "Cuối tuần bạn làm gì?"
        },
        {
          "japanese": "テニスを します。",
          "vietnamese": "Tôi chơi tennis."
        }
      ]
    }
  ],
