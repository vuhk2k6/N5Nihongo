  "grammar": [
    {
      "grammarId": 1101,
      "lessonId": 11,
      "title": "N が ～つ / ～人 あります/います",
      "structure": "N が (số đếm) あります/います",
      "explanation": "Số đếm đặt sau が hoặc trước động từ. Bộ đếm phụ thuộc vào loại danh từ.",
      "examples": [
        {
          "japanese": "りんごが 三つ あります。",
          "vietnamese": "Có 3 quả táo."
        },
        {
          "japanese": "子供が 二人 います。",
          "vietnamese": "Có 2 đứa trẻ."
        }
      ]
    },
    {
      "grammarId": 1102,
      "lessonId": 11,
      "title": "N を ～(số lượng) V ます",
      "structure": "N を (số lượng) V ます",
      "explanation": "Khi đi cùng động từ, số lượng đặt trước động từ, không cần trợ từ phía sau.",
      "examples": [
        {
          "japanese": "80円の 切手を 5枚 ください。",
          "vietnamese": "Cho tôi 5 con tem 80 yên."
        },
        {
          "japanese": "コーヒーを 一杯 飲みました。",
          "vietnamese": "Tôi đã uống một cốc cà phê."
        }
      ]
    },
    {
      "grammarId": 1103,
      "lessonId": 11,
      "title": "(期間) に ～回 V ます",
      "structure": "N(期間) に ～かい V ます",
      "explanation": "Diễn đạt tần suất. Trong khoảng thời gian N, làm ~ lần.",
      "examples": [
        {
          "japanese": "1か月に 2回 映画を 見ます。",
          "vietnamese": "Tôi xem phim 2 lần một tháng."
        },
        {
          "japanese": "1週間に 3回 テニスを します。",
          "vietnamese": "Tôi chơi tennis 3 lần một tuần."
        }
      ]
    },
    {
      "grammarId": 1104,
      "lessonId": 11,
      "title": "(期間) V ます (Khoảng thời gian)",
      "structure": "～時間 / ～か月 / ～年 V ます",
      "explanation": "Bộ đếm khoảng thời gian không cần trợ từ. Diễn đạt khoảng thời gian thực hiện hành động.",
      "examples": [
        {
          "japanese": "毎日 7時間 働きます。",
          "vietnamese": "Mỗi ngày tôi làm việc 7 tiếng."
        },
        {
          "japanese": "3年 日本語を 勉強しました。",
          "vietnamese": "Tôi đã học tiếng Nhật 3 năm."
        }
      ]
    }
