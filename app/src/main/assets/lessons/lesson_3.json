  "grammar": [
    {
      "grammarId": 301,
      "lessonId": 3,
      "title": "ここ / そこ / あそこ は N です",
      "structure": "ここ / そこ / あそこ は N です",
      "explanation": "Dùng để giới thiệu địa điểm. ここ: chỗ người nói. そこ: chỗ người nghe. あそこ: chỗ xa cả hai.",
      "examples": [
        {
          "japanese": "ここは 教室です。",
          "vietnamese": "Đây là phòng học."
        },
        {
          "japanese": "あそこは 食堂です。",
          "vietnamese": "Đằng kia là nhà ăn."
        }
      ]
    },
    {
      "grammarId": 302,
      "lessonId": 3,
      "title": "N は どこ ですか",
      "structure": "N は どこ ですか",
      "explanation": "Hỏi vị trí của N. Trả lời bằng ここ/そこ/あそこ hoặc tên địa điểm.",
      "examples": [
        {
          "japanese": "お手洗いは どこですか。",
          "vietnamese": "Nhà vệ sinh ở đâu?"
        },
        {
          "japanese": "エレベーターは あそこです。",
          "vietnamese": "Thang máy ở đằng kia."
        }
      ]
    },
    {
      "grammarId": 303,
      "lessonId": 3,
      "title": "N は ～階 です",
      "structure": "N は ～かい/がい です",
      "explanation": "Nói tầng. 1階 = いっかい, 2階 = にかい, 3階 = さんがい, 4階 = よんかい. なんがい hoặc なんかい = mấy tầng.",
      "examples": [
        {
          "japanese": "食堂は 2階です。",
          "vietnamese": "Nhà ăn ở tầng 2."
        },
        {
          "japanese": "会議室は 何階ですか。",
          "vietnamese": "Phòng họp ở tầng mấy?"
        }
      ]
    },
    {
      "grammarId": 304,
      "lessonId": 3,
      "title": "N1 は N2(国/会社/学校) の N3 です",
      "structure": "N1 は N2 の N3 です",
      "explanation": "Diễn tả xuất xứ, nơi sản xuất. の dùng để gắn nguồn gốc hoặc nơi chốn vào danh từ.",
