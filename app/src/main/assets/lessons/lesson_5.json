  "grammar": [
    {
      "grammarId": 501,
      "lessonId": 5,
      "title": "N(場所) へ 行きます/来ます/帰ります",
      "structure": "N へ いきます / きます / かえります",
      "explanation": "Trợ từ へ (đọc e) đứng sau danh từ chỉ địa điểm để biểu thị phương hướng di chuyển.",
      "examples": [
        {
          "japanese": "京都へ 行きます。",
          "vietnamese": "Tôi đi Kyoto."
        },
        {
          "japanese": "日本へ 来ました。",
          "vietnamese": "Tôi đã đến Nhật Bản."
        },
        {
          "japanese": "うちへ 帰ります。",
          "vietnamese": "Tôi về nhà."
        }
      ]
    },
    {
      "grammarId": 502,
      "lessonId": 5,
      "title": "N(乗り物) で 行きます",
      "structure": "N で いきます/きます/かえります",
      "explanation": "Trợ từ で chỉ phương tiện. Lưu ý: đi bộ không dùng で → 歩いて 行きます.",
      "examples": [
        {
          "japanese": "電車で 会社へ 行きます。",
          "vietnamese": "Tôi đi làm bằng tàu điện."
        },
        {
          "japanese": "歩いて 学校へ 行きます。",
          "vietnamese": "Tôi đi bộ đến trường."
        }
      ]
    },
    {
      "grammarId": 503,
      "lessonId": 5,
      "title": "N(人/動物) と V",
      "structure": "N と V",
      "explanation": "Trợ từ と chỉ người/động vật cùng làm hành động. Một mình → 一人で.",
      "examples": [
        {
          "japanese": "友達と 京都へ 行きます。",
          "vietnamese": "Tôi đi Kyoto cùng bạn."
        },
        {
          "japanese": "家族と ベトナムへ 帰ります。",
          "vietnamese": "Tôi về Việt Nam với gia đình."
        }
      ]
    },
    {
      "grammarId": 504,
      "lessonId": 5,
      "title": "いつ V",
      "structure": "いつ V ますか",
      "explanation": "いつ = khi nào. Dùng để hỏi thời gian xảy ra hành động. Trả lời không cần đi kèm trợ từ に khi nói các từ như 今日/明日.",
      "examples": [
        {
          "japanese": "いつ 日本へ 来ましたか。",
          "vietnamese": "Bạn đến Nhật khi nào?"
        },
        {
          "japanese": "3月25日に 来ました。",
          "vietnamese": "Tôi đến vào ngày 25 tháng 3."
        }
      ]
    }
  ],
