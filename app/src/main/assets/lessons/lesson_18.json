  "grammar": [
    {
      "grammarId": 1801,
      "lessonId": 18,
      "title": "Cách chia 辞書形 (V dictionary form)",
      "structure": "Nhóm I / II / III",
      "explanation": "Nhóm I: ます → cột う (買います→買う). Nhóm II: bỏ ます thêm る (食べる). Nhóm III: します→する, きます→くる.",
      "examples": [
        {
          "japanese": "読みます → 読む",
          "vietnamese": "yomimasu → yomu"
        },
        {
          "japanese": "食べます → 食べる",
          "vietnamese": "tabemasu → taberu"
        },
        {
          "japanese": "します → する",
          "vietnamese": "shimasu → suru"
        }
      ]
    },
    {
      "grammarId": 1802,
      "lessonId": 18,
      "title": "N / V(辞書形) ことが できます",
      "structure": "N / V(辞書形) こと が できます",
      "explanation": "Diễn đạt khả năng hoặc hoàn cảnh cho phép. Có thể ~.",
      "examples": [
        {
          "japanese": "ミラーさんは 漢字を 読む ことが できます。",
          "vietnamese": "Anh Miller có thể đọc chữ Hán."
        },
        {
          "japanese": "カードで 払う ことが できます。",
          "vietnamese": "Có thể trả bằng thẻ."
        },
        {
          "japanese": "日本語を 話す ことが できますか。",
          "vietnamese": "Bạn nói được tiếng Nhật không?"
        }
      ]
    },
    {
