  "grammar": [
    {
      "grammarId": 801,
      "lessonId": 8,
      "title": "N は い-adj いです / な-adj です",
      "structure": "N は い-adj いです / な-adj です",
      "explanation": "Câu dùng tính từ làm vị ngữ. い-adj giữ nguyên. な-adj bỏ な.",
      "examples": [
        {
          "japanese": "富士山は 高いです。",
          "vietnamese": "Núi Phú Sĩ cao."
        },
        {
          "japanese": "奈良は 静かです。",
          "vietnamese": "Nara yên tĩnh."
        }
      ]
    },
    {
      "grammarId": 802,
      "lessonId": 8,
      "title": "Phủ định và quá khứ của tính từ trong thì hiện tại/quá khứ",
      "structure": "い-adj → くないです / な-adj → じゃ ありません",
      "explanation": "い-adj: bỏ い thêm くないです. な-adj: bỏ な thêm じゃ ありません. いい thành よくない (bất quy tắc).",
      "examples": [
        {
          "japanese": "この 部屋は 広くないです。",
          "vietnamese": "Phòng này không rộng."
        },
        {
          "japanese": "ここは 静かじゃ ありません。",
          "vietnamese": "Chỗ này không yên tĩnh."
        }
      ]
    },
    {
      "grammarId": 803,
      "lessonId": 8,
      "title": "い-adj い + N / な-adj な + N",
      "structure": "い-adj い N / な-adj な N",
      "explanation": "Tính từ bổ nghĩa trực tiếp cho danh từ. い-adj giữ nguyên. な-adj giữ な.",
      "examples": [
        {
          "japanese": "大きい かばんです。",
          "vietnamese": "Cái cặp to."
        },
        {
          "japanese": "きれいな 花です。",
          "vietnamese": "Bông hoa đẹp."
        }
      ]
    },
    {
      "grammarId": 804,
      "lessonId": 8,
      "title": "N は どうですか / どんな N ですか",
      "structure": "N は どうですか / どんな N ですか",
      "explanation": "どう = thế nào (hỏi cảm nhận). どんな + N = loại ~ nào (hỏi tính chất).",
      "examples": [
        {
          "japanese": "日本の 生活は どうですか。",
          "vietnamese": "Cuộc sống ở Nhật thế nào?"
        },
        {
          "japanese": "奈良は どんな 町ですか。",
          "vietnamese": "Nara là thành phố như thế nào?"
        }
      ]
    }
  ],
