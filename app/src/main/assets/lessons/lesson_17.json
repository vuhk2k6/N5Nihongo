  "grammar": [
    {
      "grammarId": 1701,
      "lessonId": 17,
      "title": "Cách chia ない形",
      "structure": "Nhóm I / II / III",
      "explanation": "Nhóm I: ます → cột あ + ない (買います→買わない). Nhóm II: ます → ない (食べない). Nhóm III: します→しない, きます→こない.",
      "examples": [
        {
          "japanese": "買います → 買わない",
          "vietnamese": "kaimasu → kawanai"
        },
        {
          "japanese": "食べます → 食べない",
          "vietnamese": "tabemasu → tabenai"
        },
        {
          "japanese": "します → しない",
          "vietnamese": "shimasu → shinai"
        }
      ]
    },
    {
      "grammarId": 1702,
      "lessonId": 17,
      "title": "V ないで ください",
      "structure": "V ない で ください",
      "explanation": "Yêu cầu không làm gì. Xin đừng ~.",
      "examples": [
        {
          "japanese": "ここで 写真を 撮らないで ください。",
          "vietnamese": "Xin đừng chụp ảnh ở đây."
        },
        {
          "japanese": "忘れないで ください。",
          "vietnamese": "Xin đừng quên."
        }
      ]
    },
    {
      "grammarId": 1703,
      "lessonId": 17,
      "title": "V なければ なりません",
      "structure": "V なければ なりません",
      "explanation": "Phải làm ~. Nghĩa vụ, bắt buộc. (Bỏ い của ない rồi thêm ければ なりません).",
      "examples": [
        {
          "japanese": "薬を 飲まなければ なりません。",
          "vietnamese": "Phải uống thuốc."
        },
        {
          "japanese": "毎日 日本語を 勉強しなければ なりません。",
          "vietnamese": "Phải học tiếng Nhật mỗi ngày."
        }
      ]
    },
    {
      "grammarId": 1704,
      "lessonId": 17,
      "title": "V なくても いいです",
      "structure": "V なくても いいです",
      "explanation": "Không cần phải làm ~. (Bỏ い của ない thêm くても いいです).",
