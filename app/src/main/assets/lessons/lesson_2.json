  "grammar": [
    {
      "grammarId": 201,
      "lessonId": 2,
      "title": "これ/それ/あれ は N です",
      "structure": "これ / それ / あれ は N です",
      "explanation": "これ chỉ vật gần người nói. それ chỉ vật gần người nghe. あれ chỉ vật xa cả hai.",
      "examples": [
        {
          "japanese": "これは 本です。",
          "vietnamese": "Đây là quyển sách."
        },
        {
          "japanese": "それは わたしの 名刺です。",
          "vietnamese": "Đó là danh thiếp của tôi."
        },
        {
          "japanese": "あれは 何ですか。",
          "vietnamese": "Cái kia là cái gì?"
        }
      ]
    },
    {
      "grammarId": 202,
      "lessonId": 2,
      "title": "この / その / あの + N",
      "structure": "この / その / あの + N",
      "explanation": "この/その/あの đi liền với danh từ để chỉ rõ vật cụ thể.",
      "examples": [
        {
          "japanese": "この本は わたしのです。",
          "vietnamese": "Quyển sách này là của tôi."
        },
        {
          "japanese": "あの人は ミラーさんです。",
          "vietnamese": "Người kia là anh Miller."
        }
      ]
    },
    {
      "grammarId": 203,
      "lessonId": 2,
      "title": "N1 の N2",
      "structure": "N1 の N2",
      "explanation": "Trợ từ の nối hai danh từ. の có thể chỉ sở hữu, nội dung, thuộc tính hoặc xuất xứ.",
      "examples": [
        {
          "japanese": "これは コンピューターの 本です。",
          "vietnamese": "Đây là sách về máy tính."
        },
        {
          "japanese": "これは わたしの かばんです。",
          "vietnamese": "Đây là cặp của tôi."
        },
        {
          "japanese": "ミラーさんは IMCの 社員です。",
          "vietnamese": "Anh Miller là nhân viên của công ty IMC."
