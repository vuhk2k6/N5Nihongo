      ]
    },
    {
      "grammarId": 204,
      "lessonId": 2,
      "title": "そう です / そう じゃ ありません",
      "structure": "はい、そうです / いいえ、そう じゃ ありません",
      "explanation": "Cách trả lời ngắn cho câu hỏi xác định N1 là N2 phải không? Khi trả lời phủ định cũng có thể dùng いいえ、ちがいます.",
