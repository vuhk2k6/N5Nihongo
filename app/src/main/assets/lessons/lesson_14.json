  "grammar": [
    {
      "grammarId": 1401,
      "lessonId": 14,
      "title": "Cách chia て形",
      "structure": "Nhóm I / II / III",
      "explanation": "Nhóm I: き→いて, ぎ→いで, み/び/に→んで, り/ち/い→って, し→して, く(行く)→って. Nhóm II: bỏ ます thêm て. Nhóm III: します→して, きます→きて.",
      "examples": [
        {
          "japanese": "書きます → 書いて",
          "vietnamese": "kakimasu → kaite"
        },
        {
          "japanese": "飲みます → 飲んで",
          "vietnamese": "nomimasu → nonde"
        },
        {
          "japanese": "食べます → 食べて",
          "vietnamese": "tabemasu → tabete"
        }
      ]
    },
    {
      "grammarId": 1402,
      "lessonId": 14,
      "title": "V て ください",
      "structure": "V て ください",
      "explanation": "Yêu cầu lịch sự. Xin hãy ~. Có thể dùng dạng nhẹ hơn: Vてくださいませんか.",
      "examples": [
        {
          "japanese": "窓を 開けて ください。",
          "vietnamese": "Hãy mở cửa sổ giùm."
        },
        {
          "japanese": "ちょっと 待って ください。",
          "vietnamese": "Hãy chờ một chút."
        }
      ]
    },
    {
      "grammarId": 1403,
      "lessonId": 14,
      "title": "V て います (Đang tiếp diễn)",
      "structure": "V て います",
      "explanation": "Diễn đạt hành động đang diễn ra ngay lúc nói.",
      "examples": [
        {
          "japanese": "ミラーさんは 今 電話を かけて います。",
          "vietnamese": "Anh Miller đang gọi điện thoại."
        },
        {
          "japanese": "今 雨が 降って います。",
          "vietnamese": "Bây giờ trời đang mưa."
        }
      ]
    },
