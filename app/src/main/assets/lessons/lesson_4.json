  "grammar": [
    {
      "grammarId": 401,
      "lessonId": 4,
      "title": "今 ～時 ～分 です",
      "structure": "いま ～じ ～ふん/ぷん です",
      "explanation": "Cách nói giờ. ～時 = giờ, ～分 = phút. 1分 = いっぷん, 3分 = さんぷん.",
      "examples": [
        {
          "japanese": "今 7時です。",
          "vietnamese": "Bây giờ là 7 giờ."
        },
        {
          "japanese": "今 3時15分です。",
          "vietnamese": "Bây giờ là 3 giờ 15 phút."
        },
        {
          "japanese": "ニューヨークは 今 何時ですか。",
          "vietnamese": "Bây giờ ở New York là mấy giờ?"
        }
      ]
    },
    {
      "grammarId": 402,
      "lessonId": 4,
      "title": "V ます / V ません / V ました / V ませんでした",
      "structure": "V ます / V ません / V ました / V ませんでした",
      "explanation": "Bốn dạng động từ thể lịch sự: khẳng định hiện tại/tương lai, phủ định hiện tại/tương lai, khẳng định quá khứ, phủ định quá khứ.",
      "examples": [
        {
          "japanese": "毎朝 6時に 起きます。",
          "vietnamese": "Mỗi sáng tôi dậy lúc 6 giờ."
        },
        {
          "japanese": "昨日 勉強しませんでした。",
          "vietnamese": "Hôm qua tôi đã không học bài."
        }
      ]
    },
    {
      "grammarId": 403,
      "lessonId": 4,
      "title": "N (thời gian) に V",
      "structure": "N(時間) に V",
      "explanation": "Trợ từ に dùng sau danh từ chỉ thời điểm cụ thể (giờ, thứ, ngày). Không dùng với 今日/明日/毎日.",
      "examples": [
        {
          "japanese": "わたしは 6時半に 起きます。",
          "vietnamese": "Tôi dậy lúc 6 giờ rưỡi."
        },
        {
          "japanese": "月曜日に 京都へ 行きます。",
          "vietnamese": "Tôi sẽ đi Kyoto vào thứ Hai."
        }
      ]
    },
    {
      "grammarId": 404,
      "lessonId": 4,
      "title": "N1 から N2 まで",
      "structure": "N1 から N2 まで",
      "explanation": "から = từ, まで = đến. Dùng cho cả thời gian và địa điểm. Có thể đứng độc lập trong câu.",
      "examples": [
        {
