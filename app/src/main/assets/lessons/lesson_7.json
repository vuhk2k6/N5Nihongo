  "grammar": [
    {
      "grammarId": 701,
      "lessonId": 7,
      "title": "N(道具) で V",
      "structure": "N で V",
      "explanation": "Trợ từ で chỉ công cụ, phương tiện thực hiện hành động.",
      "examples": [
        {
          "japanese": "箸で ご飯を 食べます。",
          "vietnamese": "Tôi ăn cơm bằng đũa."
        },
        {
          "japanese": "日本語で レポートを 書きます。",
          "vietnamese": "Tôi viết báo cáo bằng tiếng Nhật."
        }
      ]
    },
    {
      "grammarId": 702,
      "lessonId": 7,
      "title": "N(人) に N(物) を あげます",
      "structure": "N に N を あげます/かします/おしえます",
      "explanation": "Cho/mượn/dạy ai cái gì. に chỉ người nhận hành động.",
      "examples": [
        {
          "japanese": "わたしは 木村さんに 花を あげます。",
          "vietnamese": "Tôi tặng hoa cho chị Kimura."
        },
        {
          "japanese": "ミラーさんは 私に 本を 貸して くれました。",
          "vietnamese": "Anh Miller cho tôi mượn sách."
        }
      ]
    },
    {
      "grammarId": 703,
      "lessonId": 7,
      "title": "N(人) に/から N を もらいます",
      "structure": "N に/から N を もらいます/かります/ならいます",
      "explanation": "Nhận/mượn/học từ ai cái gì. に hoặc から chỉ người cho/dạy.",
      "examples": [
        {
          "japanese": "わたしは 山田さんに 本を もらいました。",
          "vietnamese": "Tôi đã nhận sách từ anh Yamada."
        },
        {
          "japanese": "母から 手紙を もらいました。",
          "vietnamese": "Tôi nhận thư từ mẹ."
        }
      ]
    },
    {
      "grammarId": 704,
      "lessonId": 7,
      "title": "もう V ました / まだ V て いません",
      "structure": "もう V ました / まだです",
      "explanation": "Hỏi đã làm chưa. もう = đã. まだ = chưa. Trả lời 'chưa' thường dùng まだです hoặc いいえ、まだ V ていません.",
      "examples": [
        {
          "japanese": "もう 昼ご飯を 食べましたか。",
          "vietnamese": "Bạn đã ăn trưa chưa?"
        },
        {
          "japanese": "はい、もう 食べました。",
          "vietnamese": "Vâng, tôi ăn rồi."
        },
        {
          "japanese": "いいえ、まだです。",
          "vietnamese": "Chưa."
        }
      ]
    }
