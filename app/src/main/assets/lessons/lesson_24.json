  "grammar": [
    {
      "grammarId": 2401,
      "lessonId": 24,
      "title": "N(người) は わたしに N を くれます",
      "structure": "N が わたしに N を くれます",
      "explanation": "Ai đó cho tôi cái gì. Chủ ngữ là người cho, mình là người nhận (thường lược bỏ わたしに).",
      "examples": [
        {
          "japanese": "山田さんが わたしに 花を くれました。",
          "vietnamese": "Anh Yamada đã cho tôi hoa."
        },
        {
          "japanese": "母が セーターを くれました。",
          "vietnamese": "Mẹ đã cho tôi áo len."
        }
      ]
    },
    {
      "grammarId": 2402,
      "lessonId": 24,
      "title": "V て あげます",
      "structure": "(私が) N(人) に V て あげます",
      "explanation": "Tôi/ai đó làm gì cho người khác. Không nên dùng trực tiếp với cấp trên (vô ý áp đặt ơn).",
      "examples": [
        {
          "japanese": "わたしは 木村さんに 本を 貸して あげました。",
          "vietnamese": "Tôi đã cho chị Kimura mượn sách."
        },
        {
          "japanese": "わたしは 友達を 駅まで 送って あげました。",
          "vietnamese": "Tôi đã tiễn bạn đến nhà ga."
        }
      ]
    },
    {
      "grammarId": 2403,
      "lessonId": 24,
      "title": "V て もらいます",
      "structure": "(私が) N(人) に V て もらいます",
      "explanation": "Được ai đó làm gì cho mình. Người làm dùng に hoặc から.",
      "examples": [
        {
          "japanese": "わたしは 鈴木さんに 日本語を 教えて もらいました。",
          "vietnamese": "Tôi đã được anh Suzuki dạy tiếng Nhật."
        },
        {
          "japanese": "わたしは 友達に 写真を 撮って もらいました。",
          "vietnamese": "Tôi được bạn chụp ảnh giúp."
        }
      ]
    },
    {
      "grammarId": 2404,
      "lessonId": 24,
      "title": "V て くれます",
      "structure": "N(人) が (わたしに) V て くれます",
      "explanation": "Ai đó làm gì cho mình (mang ơn). Chủ ngữ là người làm.",
      "examples": [
        {
          "japanese": "佐藤さんが 駅まで 送って くれました。",
          "vietnamese": "Chị Sato đã tiễn tôi ra ga."
        },
        {
          "japanese": "母が セーターを 送って くれました。",
          "vietnamese": "Mẹ đã gửi áo len cho tôi."
        }
      ]
    }
