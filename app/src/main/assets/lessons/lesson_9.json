  "grammar": [
    {
      "grammarId": 901,
      "lessonId": 9,
      "title": "N が 好きです / 嫌いです",
      "structure": "N が すき / きらい です",
      "explanation": "Diễn đạt thích/ghét cái gì. が chỉ đối tượng của tính từ.",
      "examples": [
        {
          "japanese": "わたしは 音楽が 好きです。",
          "vietnamese": "Tôi thích âm nhạc."
        },
        {
          "japanese": "野菜が 嫌いです。",
          "vietnamese": "Tôi ghét rau."
        }
      ]
    },
    {
      "grammarId": 902,
      "lessonId": 9,
      "title": "N が 上手です / 下手です",
      "structure": "N が じょうず / へた です",
      "explanation": "Diễn đạt giỏi/kém ở lĩnh vực nào đó.",
      "examples": [
        {
          "japanese": "ミラーさんは 日本語が 上手です。",
          "vietnamese": "Anh Miller giỏi tiếng Nhật."
        },
        {
          "japanese": "わたしは 料理が 下手です。",
          "vietnamese": "Tôi nấu ăn kém."
        }
      ]
    },
    {
      "grammarId": 903,
      "lessonId": 9,
      "title": "N が わかります / N が あります",
      "structure": "N が わかります / あります",
      "explanation": "わかります = hiểu, biết; あります = có (đồ vật / sự kiện). Đối tượng dùng が.",
      "examples": [
        {
          "japanese": "日本語が わかります。",
          "vietnamese": "Tôi hiểu tiếng Nhật."
        },
        {
          "japanese": "明日 テストが あります。",
          "vietnamese": "Ngày mai có bài kiểm tra."
        }
      ]
    },
    {
      "grammarId": 904,
      "lessonId": 9,
      "title": "～から、～ (Lý do)",
      "structure": "S1 から、S2",
      "explanation": "から đặt sau câu lý do để giải thích. S1 là lý do, S2 là kết quả.",
      "examples": [
        {
          "japanese": "時間が ありませんから、新聞を 読みません。",
          "vietnamese": "Vì không có thời gian nên tôi không đọc báo."
        },
        {
          "japanese": "どうして 京都へ 行きますか。…きれいな お寺が ありますから。",
          "vietnamese": "Tại sao bạn đến Kyoto? – Vì có những ngôi chùa đẹp."
        }
      ]
    }
