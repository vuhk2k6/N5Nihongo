  "grammar": [
    {
      "grammarId": 1201,
      "lessonId": 12,
      "title": "Quá khứ của tính từ và danh từ",
      "structure": "い-adj → ～かったです / な-adj/N → ～でした",
      "explanation": "い-adj: bỏ い thêm かったです / khẳng định và くなかったです / phủ định. な-adj/N: でした / じゃ ありませんでした.",
      "examples": [
        {
          "japanese": "昨日は 暑かったです。",
          "vietnamese": "Hôm qua trời nóng."
        },
        {
          "japanese": "旅行は にぎやかでした。",
          "vietnamese": "Chuyến du lịch nhộn nhịp."
        },
        {
          "japanese": "試験は 簡単じゃ ありませんでした。",
          "vietnamese": "Bài thi đã không dễ."
        }
      ]
    },
    {
      "grammarId": 1202,
      "lessonId": 12,
      "title": "N1 は N2 より ～です",
      "structure": "N1 は N2 より adj です",
      "explanation": "So sánh hơn. N1 hơn N2 về tính chất ~.",
      "examples": [
        {
          "japanese": "東京は 大阪より 大きいです。",
          "vietnamese": "Tokyo lớn hơn Osaka."
        },
        {
          "japanese": "飛行機は 新幹線より 速いです。",
          "vietnamese": "Máy bay nhanh hơn Shinkansen."
        }
      ]
    },
    {
      "grammarId": 1203,
      "lessonId": 12,
      "title": "N1 と N2 と どちらが ～ですか",
      "structure": "N1 と N2 と どちらが ～ですか",
      "explanation": "Hỏi so sánh giữa hai đối tượng. Trả lời: ～のほうが ～です.",
      "examples": [
        {
          "japanese": "コーヒーと 紅茶と どちらが 好きですか。",
          "vietnamese": "Cà phê và hồng trà, bạn thích cái nào hơn?"
        },
        {
          "japanese": "コーヒーのほうが 好きです。",
          "vietnamese": "Tôi thích cà phê hơn."
        }
      ]
    },
    {
      "grammarId": 1204,
      "lessonId": 12,
      "title": "N1 [の 中] で N2 が いちばん ～です",
      "structure": "N1 (の中で) N2 が いちばん ～です",
      "explanation": "So sánh nhất. Trong N1, N2 là ~ nhất. Với địa điểm/thời gian: で thay cho の中で.",
      "examples": [
        {
          "japanese": "季節の 中で 春が いちばん 好きです。",
          "vietnamese": "Trong các mùa, tôi thích mùa xuân nhất."
        },
        {
          "japanese": "クラスの 中で だれが いちばん 上手ですか。",
          "vietnamese": "Trong lớp, ai giỏi nhất?"
        }
      ]
    }
