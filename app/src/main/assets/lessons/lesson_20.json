  "grammar": [
    {
      "grammarId": 2001,
      "lessonId": 20,
      "title": "Thể thường (普通形)",
      "structure": "V/い-adj/な-adj/N → thể thường",
      "explanation": "V: 行く/行かない/行った/行かなかった. い-adj: 高い/高くない/高かった/高くなかった. な-adj: 静かだ/静かじゃない. N: 学生だ/学生じゃない.",
      "examples": [
        {
          "japanese": "行きます → 行く",
          "vietnamese": "ikimasu → iku"
        },
        {
          "japanese": "高いです → 高い",
          "vietnamese": "takai desu → takai"
        },
        {
          "japanese": "学生です → 学生だ",
          "vietnamese": "gakusei desu → gakusei da"
        }
      ]
    },
    {
      "grammarId": 2002,
      "lessonId": 20,
      "title": "Hội thoại thân mật (普通体)",
      "structure": "Câu thân mật bỏ です/ます, thay bằng thể thường",
      "explanation": "Dùng trong gia đình, bạn bè cùng tuổi/dưới mình. Câu hỏi thường bỏ か, lên giọng cuối câu.",
      "examples": [
        {
          "japanese": "明日 来る？",
          "vietnamese": "Ngày mai đến không?"
        },
        {
          "japanese": "うん、行く。",
          "vietnamese": "Ừ, đi."
        },
        {
          "japanese": "ううん、行かない。",
          "vietnamese": "Không, không đi."
        }
      ]
    },
    {
      "grammarId": 2003,
      "lessonId": 20,
      "title": "Phân biệt は và が",
      "structure": "N が adj です / N は adj です",
      "explanation": "が dùng khi giới thiệu thông tin mới, trả lời câu hỏi 'cái nào'. は dùng khi nói về chủ đề đã biết.",
      "examples": [
        {
          "japanese": "どれが ミラーさんの 傘ですか。 …これです。",
          "vietnamese": "Cái nào là ô của anh Miller? – Cái này."
        },
        {
          "japanese": "ミラーさんの 傘は どれですか。",
          "vietnamese": "Ô của anh Miller là cái nào?"
        }
      ]
    },
    {
      "grammarId": 2004,
      "lessonId": 20,
      "title": "わたしは ～が ある／いる",
      "structure": "Câu thân mật của V て います, あります, います",
      "explanation": "Dùng để hỏi/đáp về việc sở hữu, sự kiện trong câu hội thoại thân mật.",
      "examples": [
        {
          "japanese": "車 ある？",
          "vietnamese": "Có ô tô không?"
        },
        {
          "japanese": "子供 いる？",
          "vietnamese": "Có con không?"
        }
      ]
    }
  ],
