        },
        {
          "japanese": "今 何が いちばん ほしいですか。",
          "vietnamese": "Bây giờ bạn muốn gì nhất?"
        }
      ]
    },
    {
      "grammarId": 1302,
      "lessonId": 13,
      "title": "V(ます形) たいです",
      "structure": "V(ます形) たいです",
      "explanation": "Diễn đạt mong muốn cá nhân làm gì đó. Bỏ ます thêm たいです.",
      "examples": [
        {
          "japanese": "海へ 行きたいです。",
          "vietnamese": "Tôi muốn đi biển."
        },
        {
          "japanese": "日本料理を 食べたいです。",
          "vietnamese": "Tôi muốn ăn món Nhật."
        },
        {
          "japanese": "疲れましたから、何も したくないです。",
          "vietnamese": "Tôi mệt rồi nên không muốn làm gì."
        }
      ]
    },
    {
      "grammarId": 1303,
      "lessonId": 13,
      "title": "N(場所) へ V(ます形)に 行きます/来ます/帰ります",
      "structure": "N へ V(ます形) に 行きます",
      "explanation": "Đi đến nơi nào để làm gì. Bỏ ます thêm に, sau đó là động từ di chuyển.",
      "examples": [
        {
          "japanese": "デパートへ 買い物に 行きます。",
          "vietnamese": "Tôi đến trung tâm thương mại để mua sắm."
        },
        {
          "japanese": "公園へ 散歩に 行きます。",
          "vietnamese": "Tôi đi công viên để đi dạo."
        }
      ]
    },
    {
      "grammarId": 1304,
      "lessonId": 13,
      "title": "なにか / どこか / だれか (Đại từ bất định)",
      "structure": "なにか / どこか / だれか",
      "explanation": "Đại từ bất định: cái gì đó, ở đâu đó, ai đó. Trong câu hỏi diễn đạt 'có ~ không'.",
      "examples": [
        {
